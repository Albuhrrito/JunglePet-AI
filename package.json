{
  "name": "junglepet-ai",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered League of Legends coach. Analyzes match history and gives actionable improvement recommendations.",
  "keywords": [
    "league-of-legends",
    "lol",
    "riot-api",
    "ai-coach",
    "gemini",
    "react",
    "vite",
    "typescript",
    "tailwindcss",
    "github-pages"
  ],
  "author": "Albuhrrito",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Albuhrrito/League-Match-History-Analyzer.git"
  },
  "homepage": "https://albuhrrito.github.io/League-Match-History-Analyzer/",
  "bugs": {
    "url": "https://github.com/Albuhrrito/League-Match-History-Analyzer/issues"
  },
  "engines": {
    "node": ">=22.13",
    "npm": ">=10.2"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
